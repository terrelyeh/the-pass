# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# pipeline runtime state (seen store + daily feed dumps)
/data/*.json

# 選題報告 demo（artifact，勿 commit）。每期 dated 報告（selection-report-YYYY-MM-DD.html）
# 由 /selection-report 產出、會 commit 上 thepass.cc 給團隊看，故不在此忽略。
public/selection-report-demo.html
